# =============================================================================
# .env.example - Environment Variables for HLS Streaming Pipeline
# Copy this file to .env and adjust values as needed.
# =============================================================================

# Segment duration in seconds (affects latency vs overhead tradeoff)
# Shorter = less latency, more files; Longer = more latency, fewer files
# Recommended: 4-10 seconds. Default: 6
SEGMENT_DURATION=6

# FFmpeg encoding preset (affects encoding speed vs compression quality)
# Options: ultrafast, superfast, veryfast, faster, fast, medium, slow, slower, veryslow
# Faster preset = faster encoding but larger files. Default: fast
FFMPEG_PRESET=fast

# Output directory inside the container
OUTPUT_DIR=/app/media/output

# Source video path inside the container
SOURCE_VIDEO=/app/video/source.mp4

# Bitrate settings (in kilobits per second)
BITRATE_1080P=5000k
BITRATE_720P=2500k
BITRATE_480P=800k

# Audio bitrate
AUDIO_BITRATE_HIGH=192k
AUDIO_BITRATE_MED=128k
